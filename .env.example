# ─────────────────────────────────────────────────────────────────────────────
# NewspaSync — secrets file
# Copy this to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email inbox (IMAP) ────────────────────────────────────────────────────────
# Only needed when EMAIL_ENABLED=true in docker-compose.yml
# Use an App Password — never your main account password.
# Gmail: myaccount.google.com/apppasswords
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your-app-password

# ── TickTick ──────────────────────────────────────────────────────────────────
# Create an app at: https://developer.ticktick.com/manage
# Only needed when TICKTICK_ENABLED=true
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=

# ── AI summaries ──────────────────────────────────────────────────────────────
# Only needed when AI_SUMMARY_ENABLED=true
# For OpenAI: platform.openai.com/api-keys
# For local Ollama: leave blank (no key needed) and set AI_API_BASE_URL=http://ollama:11434/v1
AI_API_KEY=
