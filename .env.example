# ─────────────────────────────────────────────────────────────────────────────
# NewspaSync — secrets file
# Copy this to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── reMarkable email sync ─────────────────────────────────────────────────────
# Required when REMARKABLE_SYNC_METHOD is "email" or "rmapi_with_email_fallback".
# Find your device address at: my.remarkable.com → Settings → Email & storage
REMARKABLE_DEVICE_EMAIL=yourdevice@mail.remarkable.com

# SMTP account used to SEND the PDF to your reMarkable device email.
# Gmail: use an App Password (myaccount.google.com/apppasswords)
# Outlook: use an App Password or enable SMTP AUTH in admin settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password

# ── Email inbox (IMAP) ────────────────────────────────────────────────────────
# Only needed when EMAIL_ENABLED=true in docker-compose.yml
# Use an App Password — never your main account password.
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your-app-password

# ── TickTick ──────────────────────────────────────────────────────────────────
# Create an app at: https://developer.ticktick.com/manage
# Only needed when TICKTICK_ENABLED=true
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=

# ── AI summaries ──────────────────────────────────────────────────────────────
# Only needed when AI_SUMMARY_ENABLED=true
# For OpenAI: platform.openai.com/api-keys
# For local Ollama: leave blank (no key needed) and set AI_API_BASE_URL=http://ollama:11434/v1
AI_API_KEY=
